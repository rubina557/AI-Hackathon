{
  "theme": {
    "name": "HireIn Premium",
    "description": "High-fidelity WhatsApp-inspired interface for informal economy service booking.",
    "colors": {
      "primary": {
        "brand": "#00A884", 
        "brand_dark": "#008f6f",
        "brand_light": "#e8f5f1"
      },
      "background": {
        "app": "#111B21",
        "chat_area": "#0B141A",
        "card": "#202C33"
      },
      "text": {
        "primary": "#E9EDEF",
        "secondary": "#8696A0",
        "inverse": "#111B21"
      },
      "urgency": {
        "scheduled": {
          "color": "#00A884",
          "background": "rgba(0, 168, 132, 0.15)",
          "glow": "rgba(0, 168, 132, 0.3)"
        },
        "urgent": {
          "color": "#F15C6D",
          "background": "rgba(241, 92, 109, 0.15)",
          "glow": "rgba(241, 92, 109, 0.4)"
        }
      },
      "chat_bubbles": {
        "user": {
          "background": "#005C4B",
          "text": "#E9EDEF"
        },
        "system": {
          "background": "#202C33",
          "text": "#E9EDEF"
        }
      }
    },
    "typography": {
      "font_family": "Inter, sans-serif",
      "weights": {
        "regular": 400,
        "medium": 500,
        "bold": 600,
        "black": 800
      },
      "sizes": {
        "h1": "28px",
        "h2": "24px",
        "body_large": "16px",
        "body_regular": "14px",
        "body_small": "12px"
      }
    },
    "glassmorphism": {
      "transparency_log_overlay": {
        "background": "rgba(32, 44, 51, 0.7)",
        "backdrop_filter": "blur(12px)",
        "border": "1px solid rgba(255, 255, 255, 0.08)",
        "box_shadow": "0 8px 32px 0 rgba(0, 0, 0, 0.3)"
      }
    },
    "micro_animations": {
      "chat_bubble_appear": {
        "duration": "300ms",
        "easing": "cubic-bezier(0.175, 0.885, 0.32, 1.275)",
        "transform": "scale(0.9) translateY(10px) to scale(1) translateY(0)"
      },
      "booking_confirmation_pulse": {
        "duration": "1.5s",
        "iteration": "infinite",
        "easing": "ease-in-out",
        "keyframes": "0% { box-shadow: 0 0 0 0 rgba(0, 168, 132, 0.4); } 70% { box-shadow: 0 0 0 15px rgba(0, 168, 132, 0); } 100% { box-shadow: 0 0 0 0 rgba(0, 168, 132, 0); }"
      },
      "transparency_panel_slide": {
        "duration": "400ms",
        "easing": "ease-out",
        "transform": "translateY(100%) to translateY(0)"
      }
    },
    "borders": {
      "radius": {
        "small": "8px",
        "medium": "12px",
        "large": "16px",
        "pill": "9999px"
      }
    }
  }
}
